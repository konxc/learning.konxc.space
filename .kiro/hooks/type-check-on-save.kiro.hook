{
  "enabled": true,
  "name": "Type Check on Save",
  "description": "Jalankan pnpm run check setiap kali file Svelte atau TypeScript disimpan untuk memastikan 0 errors dan 0 warnings.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/**/*.svelte",
      "src/**/*.ts"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "pnpm run check"
  }
}
