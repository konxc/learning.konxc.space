{
	"name": "Type Check on Save",
	"version": "1.0.0",
	"description": "Jalankan pnpm run check setiap kali file TypeScript server disimpan untuk memastikan 0 errors dan 0 warnings.",
	"when": {
		"type": "fileEdited",
		"patterns": [
			"src/**/*.server.ts",
			"src/lib/server/**/*.ts",
			"src/lib/constants/**/*.ts"
		]
	},
	"then": {
		"type": "runCommand",
		"command": "pnpm run check"
	}
}
