{
	"mcpServers": {
		"svelte": {
			"command": "npx",
			"args": ["-y", "@sveltejs/mcp"]
		},
		"mcp-svelte-docs": {
			"command": "npx",
			"args": ["-y", "mcp-svelte-docs"]
		},
		"tailwindcss-server": {
			"command": "npx",
			"args": ["-y", "tailwindcss-mcp-server"]
		},
		"filesystem": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-filesystem"]
		},
		"ripgrep": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-ripgrep"]
		},
		"process": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-process"]
		},
		"eslint": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-eslint"]
		}
	}
}
