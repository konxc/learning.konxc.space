FROM node:22-alpine

# ============================================================
# Match host user (dev:1000) so bind-mounted files stay writable
# ============================================================
ARG USER_ID=1000
ARG GROUP_ID=1000
RUN addgroup -g ${GROUP_ID} devuser 2>/dev/null || true \
 && adduser -u ${USER_ID} -G devuser -D devuser 2>/dev/null || true

WORKDIR /app

# Install pnpm (as root, so it's available globally)
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy package files and install deps as root
COPY package.json pnpm-lock.yaml ./
RUN pnpm install

# Only chown node_modules (persists in named volume)
# Source files are bind-mounted from the host — already owned by dev:dev
RUN chown -R ${USER_ID}:${GROUP_ID} /app/node_modules

# Switch to host-matching user for all runtime operations
USER ${USER_ID}

EXPOSE 3000

# pnpm dev runs as uid 1000 → files generated in .svelte-kit/
# (inside the bind mount) are owned by dev:dev on the host
CMD ["pnpm", "dev", "--host", "0.0.0.0", "--port", "3000"]
