# Replace with your DB credentials!
DATABASE_URL="libsql://db-name-user.turso.io"
DATABASE_AUTH_TOKEN=""
# A local DB can also be used in dev as well
# DATABASE_URL="file:local.db"

# =============================================================================
# Feature Flags - Toggle features on/off for the application
# =============================================================================
# Set to 'true' to enable, 'false' to disable

# PWA (Progressive Web App) - manifest, service worker, mobile meta tags
# Default: false (disabled)
PWA_ENABLED=false

# Analytics (Umami)
# Default: true (enabled)
ANALYTICS_ENABLED=true

# Service Worker for caching
# Default: false (disabled)
SW_ENABLED=false
